# Anthropic API Key — for generating replies
ANTHROPIC_API_KEY=sk-ant-your-key-here

# Gmail OAuth2 Credentials
GMAIL_CLIENT_ID=your-client-id.apps.googleusercontent.com
GMAIL_CLIENT_SECRET=your-client-secret
GMAIL_REFRESH_TOKEN=your-refresh-token

# Your email address (for the From field)
FROM_EMAIL=you@example.com

# Optional: Notion page for cost reporting
# NOTION_TOKEN=ntn_your-token
# NOTION_PAGE_ID=your-page-id

# Optional: WhatsApp link for CTA
# WA_PROGRAM_URL=https://wa.me/YOUR_NUMBER?text=message
