}"""

    step1_result = _api_call_json(client, model, step1_prompt, transcript, file_name, logger)
    if not step1_result:
        logger.error("  שלב 1 נכשל!")
        return {"output_text": "", "is_error": True, "error_reason": "שלב 1 (זיהוי נושאים) נכשל"}

    topics = step1_result.get("topics", [])
    metadata = step1_result.get("metadata", {})
    flow_summary = step1_result.get("flow_summary", "")
    logger.info(f"  זוהו {len(topics)} נושאים: {[t.get('name', '') for t in topics]}")

    # ─── שלב 2: העמקה בכל נושא ───
    logger.info(f"  שלב 2/4: העמקה ב-{len(topics)} נושאים...")

    deep_topics = []
    for i, topic in enumerate(topics):
        topic_name = topic.get("name", f"נושא {i+1}")
        logger.info(f"    מעמיק בנושא {i+1}/{len(topics)}: {topic_name}")

        step2_prompt = f"""אתה עורך ידע הדרכתי מומחה. קיבלת תמלול של שיעור AI.

המשימה שלך: התמקד **רק** בנושא "{topic_name}" וחלץ ממנו את כל הערך.
{f'טווח זמן משוער: {topic.get("time_range", "לא ידוע")}' if topic.get("time_range") else ''}
{f'תיאור: {topic.get("description", "")}' if topic.get("description") else ''}

חלץ את הפריטים הבאים (כתוב כל אחד בעומק, לא רשימות יבשות):

