def _generate_general_summary(transcript: str, file_name: str,
                               client: OpenAI, model: str, logger: logging.Logger) -> dict:
    """מייצר סיכום קצר למסלול other_general."""

    system_prompt = """אתה מקבל תמלול של פגישה שלא נכנסת לאף קטגוריה ייעודית.
כתוב סיכום קצר של 3-5 משפטים בעברית שמתאר:
1. על מה הייתה הפגישה
2. מי השתתף (אם ניתן לזהות)
3. למה היא לא נכנסת לקטגוריות: הטמעה, פנימית, מכירה ארגונית, אפיון, חילוץ עומק, שיעור
כתוב בסגנון תמציתי ועובדתי."""

    user_message = f'file_name: "{file_name}"\n\ntranscript:\n{transcript[:8000]}'

    def do_summarize():
        response = client.chat.completions.create(
            model=model,
            messages=[
                {"role": "system", "content": system_prompt},
                {"role": "user", "content": user_message},
            ],
            temperature=0.3,
        )
        return response.choices[0].message.content

    try:
        summary = api_call_with_retry(do_summarize, logger=logger)
        return {"output_text": summary, "is_error": False, "error_reason": None}
    except Exception as e:
        logger.error(f"שגיאת סיכום כללי: {e}")
        return {"output_text": "", "is_error": True, "error_reason": str(e)}


