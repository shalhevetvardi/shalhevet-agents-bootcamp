def format_output_for_notion(output_text: str, route_id: str) -> str:
    """ממיר את הפלט לפורמט Notion markdown קריא.

    רוב הפרומפטים מחזירים טקסט מפורמט (TEXT_OUTPUT_ROUTES) — מועבר כמו שהוא.
    JSON טהור (כמו org_depth_extraction_for_content) — ממיר למרקדאון קריא.
    """
    # קודם ננסה JSON — רלוונטי בעיקר ל-org_depth_extraction_for_content
    try:
        data = json.loads(output_text)
        return _json_to_notion_markdown(data, route_id)
    except (json.JSONDecodeError, ValueError):
        pass

    # טקסט מפורמט — כבר מוכן, מעבירים כמו שהוא
    return output_text


