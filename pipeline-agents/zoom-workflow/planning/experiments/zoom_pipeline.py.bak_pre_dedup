def _clean_timestamps(obj):
    """מנקה שדות time_start/time_end מטקסט מיותר שהמודל מוסיף.
    למשל: '00:05:18 — מתי התחילו להסביר' → '00:05:18'
    """
    ts_pattern = re.compile(r'^(\d{2}:\d{2}:\d{2})')

    if isinstance(obj, dict):
        for key, val in obj.items():
            if key in ("time_start", "time_end", "timestamp") and isinstance(val, str):
                match = ts_pattern.match(val.strip())
                if match:
                    obj[key] = match.group(1)
            else:
                _clean_timestamps(val)
    elif isinstance(obj, list):
        for item in obj:
            _clean_timestamps(item)
    return obj


def _api_call_json(client: OpenAI, model: str, system_prompt: str,
                   transcript: str, file_name: str, logger: logging.Logger) -> Optional[dict]:
    """קריאת API שמחזירה JSON מפורסס."""

    user_message = f'file_name: "{file_name}"\n\ntranscript:\n{transcript}'

    def do_call():
        response = client.chat.completions.create(
            model=model,
            messages=[
                {"role": "system", "content": system_prompt},
                {"role": "user", "content": user_message},
            ],
            temperature=0.2,
            response_format={"type": "json_object"},
        )
        return response.choices[0].message.content

    try:
        raw = api_call_with_retry(do_call, logger=logger)
        parsed = json.loads(raw)
        return _clean_timestamps(parsed)
    except Exception as e:
        logger.error(f"שגיאה בקריאת API: {e}")
        return None


def _assemble_knowledge_doc(metadata: dict, flow_summary: str,
                             deep_topics: list, cross_topics: Optional[dict],
                             original_prompt: str, logger: logging.Logger) -> str:
    """מרכיב את כל חלקי העיבוד הרב-שלבי למסמך ידע אחד + JSON אינדקס."""

    sections = []

    # ─── מטא-נתונים ───
    sections.append("מטא-נתונים")
    sections.append(f"כותרת השיעור: {metadata.get('lesson_title', 'לא צוין בשיחה')}")
    if metadata.get('lesson_number'):
        sections.append(f"מספר שיעור: {metadata['lesson_number']}")
    if metadata.get('course_cycle'):
        sections.append(f"מחזור: {metadata['course_cycle']}")
    sections.append(f"מדריך/ה: {metadata.get('instructor', 'לא צוין בשיחה')}")
    sections.append(f"שפת השיעור: {metadata.get('language', 'עברית')}")

    topic_names = [t.get('topic_name', '') for t in deep_topics]
    if topic_names:
        sections.append(f"נושאים מרכזיים: {', '.join(topic_names)}")

    sections.append("")

    # ─── תקציר כללי ───
    sections.append("תקציר כללי של השיעור")
    sections.append(flow_summary if flow_summary else "לא זמין")
    sections.append("")

    # ─── פירוט לפי נושאים ───
    all_prompts = []
    all_mistakes = []
    all_wow = []
    all_before_after = []
    all_tools = []
    all_processes = []
    all_qa = []

    for topic in deep_topics:
        idx = topic.get("topic_index", "")
        name = topic.get("topic_name", "")
        time_range = topic.get("time_range", "")

        sections.append(f"נושא {idx} — {name}")
        if time_range:
            sections.append(f"טווח זמן: {time_range}")
        sections.append("")

        # תמצית
        summary = topic.get("summary", topic.get("topic_summary", ""))
        if summary:
            sections.append("תמצית הנושא")
            if isinstance(summary, list):
                sections.extend(summary)
            else:
                sections.append(summary)
            sections.append("")

        # תהליכים
        processes = topic.get("processes", topic.get("processes_step_by_step", []))
        if processes:
            sections.append("תהליכים ושיטות שהוצגו")
            for proc in processes:
                if isinstance(proc, dict):
                    proc_name = proc.get("name", proc.get("process_name", ""))
                    sections.append(f"תהליך: {proc_name}")
                    steps = proc.get("steps", [])
                    for j, step in enumerate(steps, 1):
                        sections.append(f"  {j}. {step}")
                    if proc.get("notes") or proc.get("warnings"):
                        sections.append(f"  דגשים: {proc.get('notes', proc.get('warnings', ''))}")
                    if proc.get('time_start') and proc.get('time_end'):
                        sections.append(f"  זמן: {proc['time_start']} — {proc['time_end']}")
                    all_processes.append(proc)
                else:
                    sections.append(f"- {proc}")
            sections.append("")

        # פרומפטים
        prompts = topic.get("prompts", topic.get("prompts_mentioned", []))
        if prompts:
            sections.append("פרומפטים")
            for pr in prompts:
                if isinstance(pr, dict):
                    text = pr.get("prompt_text", pr.get("text", ""))
                    source = pr.get("source", "תמלול")
                    ts = pr.get("timestamp", "")
                    sections.append(f"פרומפט: {text}")
                    sections.append(f"  מקור: {source}")
                    if ts:
                        sections.append(f"  timestamp: {ts}")
                    all_prompts.append(pr)
                else:
