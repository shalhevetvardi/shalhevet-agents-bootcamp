        topic_result = _api_call_json(client, model, step2_prompt, transcript, file_name, logger)
        if topic_result:
            topic_result["topic_name"] = topic_name
            topic_result["topic_index"] = i + 1
            topic_result["time_range"] = topic.get("time_range", "")
            deep_topics.append(topic_result)
        else:
            logger.warning(f"    נושא {topic_name} — העמקה נכשלה")

    # ─── שלב 3: רכיבים חוצי-נושאים ───
    logger.info("  שלב 3/4: חילוץ רכיבים חוצי-נושאים...")

    step3_prompt = """אתה עורך ידע הדרכתי. קיבלת תמלול של שיעור AI.

המשימה: חלץ רכיבים שחוצים את כל הנושאים של השיעור:

1. תובנות על-נושאיות — עקרונות או רעיונות שנגעו בכמה נושאים.
