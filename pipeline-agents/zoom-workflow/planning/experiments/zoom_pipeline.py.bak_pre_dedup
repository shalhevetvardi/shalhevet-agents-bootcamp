def setup_logging(log_file: str) -> logging.Logger:
    """הגדרת לוג לקובץ ולמסך."""
    logger = logging.getLogger("zoom_pipeline")
    logger.setLevel(logging.DEBUG)

    fmt = logging.Formatter("%(asctime)s [%(levelname)s] %(message)s", datefmt="%Y-%m-%d %H:%M:%S")

    fh = logging.FileHandler(log_file, encoding="utf-8")
    fh.setLevel(logging.DEBUG)
    fh.setFormatter(fmt)
    logger.addHandler(fh)

    ch = logging.StreamHandler()
    ch.setLevel(logging.INFO)
    ch.setFormatter(fmt)
    logger.addHandler(ch)

    return logger


def load_config(config_path: str) -> dict:
    """טוען קובץ הגדרות JSON."""
    with open(config_path, "r", encoding="utf-8") as f:
        return json.load(f)


def load_processed_files(path: str) -> dict:
    """טוען רשימת קבצים שכבר עובדו."""
    if os.path.exists(path):
        with open(path, "r", encoding="utf-8") as f:
            return json.load(f)
    return {}


def save_processed_files(path: str, data: dict):
    """שומר רשימת קבצים שעובדו."""
    with open(path, "w", encoding="utf-8") as f:
        json.dump(data, f, ensure_ascii=False, indent=2)


def _normalize_path(path: str) -> str:
    """מנרמל נתיב — מחליף את תיקיית הבית ב-~ כדי שיעבוד בכל מחשב (iCloud sync)."""
    home = os.path.expanduser("~")
    if path.startswith(home):
        return "~" + path[len(home):]
    return path



def extract_date_from_folder(folder_name: str, file_path: str = None) -> Optional[str]:
    """מחלץ תאריך מתוך שם תיקיית זום.
    פורמט: YYYY-MM-DD HH.MM.SS ...
    מחזיר: YYYY-MM-DD או None.
    אם אין תאריך בשם ויש file_path — משתמש בתאריך השינוי של הקובץ כ-fallback.
    """
    match = re.match(r"(\d{4}-\d{2}-\d{2})", folder_name)
    if match:
        return match.group(1)
    # fallback: תאריך שינוי הקובץ
    if file_path:
        try:
            from datetime import datetime
            mtime = Path(file_path).stat().st_mtime
            return datetime.fromtimestamp(mtime).strftime("%Y-%m-%d")
        except Exception:
            pass
    return None


def detect_language(text: str) -> str:
    """זיהוי שפה פשוט על בסיס תווים עבריים.
    >70% עברית → עברית, >70% אנגלית → אנגלית, אחרת → מעורב
    """
    if not text:
        return "מעורב"

    hebrew_chars = len(re.findall(r'[\u0590-\u05FF]', text))
    latin_chars = len(re.findall(r'[a-zA-Z]', text))
    total = hebrew_chars + latin_chars

    if total == 0:
        return "מעורב"

    hebrew_ratio = hebrew_chars / total
    if hebrew_ratio > 0.7:
        return "עברית"
    elif hebrew_ratio < 0.3:
        return "אנגלית"
    else:
        return "מעורב"


def api_call_with_retry(func, max_retries=3, logger=None):
    """מבצע קריאת API עם retry ו-exponential backoff."""
    for attempt in range(max_retries):
        try:
            return func()
        except Exception as e:
            wait_time = 2 ** attempt * 5  # 5, 10, 20 שניות
            if logger:
                logger.warning(f"ניסיון {attempt + 1}/{max_retries} נכשל: {e}. ממתין {wait_time} שניות...")
            if attempt < max_retries - 1:
                time.sleep(wait_time)
            else:
                raise


# ─── שלב 0: סריקת תיקיית זום ────────────────────────────────────

def scan_zoom_folder(zoom_path: str, processed: dict, logger: logging.Logger) -> list:
    """סורק את תיקיית הזום ומחזיר רשימת הקלטות חדשות.

    מחזיר: רשימה של dicts עם:
      - folder_name: שם התיקייה
      - audio_path: נתיב מלא לקובץ אודיו
      - date: תאריך מחולץ או None
    """
    new_recordings = []
    zoom_dir = Path(zoom_path)

    if not zoom_dir.exists():
        logger.error(f"תיקיית זום לא נמצאה: {zoom_path}")
        return []

    for item in sorted(zoom_dir.iterdir()):
        # --- קבצי אודיו ישירות בתיקיית Zoom ---
        if item.is_file() and item.suffix.lower() in ('.m4a', '.mp3'):
            file_key = _normalize_path(str(item))
            if file_key in processed:
                continue
            size_mb = item.stat().st_size / (1024 * 1024)
            # שם התיקייה = שם הקובץ בלי סיומת
            display_name = item.stem
            new_recordings.append({
                "folder_name": display_name,
                "audio_path": _normalize_path(str(item)),
                "audio_filename": item.name,
                "date": extract_date_from_folder(display_name, str(item)),
                "size_mb": round(size_mb, 1),
            })
            continue

        # --- תת-תיקיות (המבנה הרגיל של Zoom) ---
        if not item.is_dir():
            continue

        # מדלג על תיקיות מיוחדות
        if item.name.startswith('.') or item.name in ('zoom-workflow', 'פרומפטים לחילוץ מתמלולים'):
            continue

        # מחפש קבצי אודיו בתיקייה
        audio_files = list(item.glob("*.m4a")) + list(item.glob("*.mp3"))
        if not audio_files:
            continue

        for audio_file in audio_files:
            file_key = _normalize_path(str(audio_file))
            if file_key in processed:
                continue

            # בודק גודל קובץ
            size_mb = audio_file.stat().st_size / (1024 * 1024)

            new_recordings.append({
                "folder_name": item.name,
                "audio_path": _normalize_path(str(audio_file)),
                "audio_filename": audio_file.name,
                "date": extract_date_from_folder(item.name, str(audio_file)),
                "size_mb": round(size_mb, 1),
            })

    logger.info(f"נמצאו {len(new_recordings)} הקלטות חדשות מתוך סה\"כ תיקיות בזום")
    return new_recordings


# ─── שלב 1: תמלול עם Whisper ─────────────────────────────────────

def _split_audio(audio_path: str, max_size_mb: float, logger: logging.Logger) -> list:
    audio_path = os.path.expanduser(audio_path)
    """מפצל קובץ אודיו גדול לחלקים קטנים באמצעות ffmpeg.

    מחזיר רשימת נתיבים לקבצים המפוצלים (בתיקייה זמנית).
    """
    # בדיקה ש-ffmpeg מותקן
    try:
        subprocess.run(["ffmpeg", "-version"], capture_output=True, check=True)
    except (FileNotFoundError, subprocess.CalledProcessError):
        logger.error("ffmpeg לא מותקן! יש להתקין: brew install ffmpeg")
        return []

    # קבלת אורך הקובץ בשניות
    probe = subprocess.run(
        ["ffprobe", "-v", "error", "-show_entries", "format=duration",
         "-of", "default=noprint_wrappers=1:nokey=1", audio_path],
        capture_output=True, text=True
    )
    total_duration = float(probe.stdout.strip())
    file_size_mb = os.path.getsize(audio_path) / (1024 * 1024)

    # חישוב כמה חלקים צריך (מרווח ביטחון גדול בגלל bitrate משתנה)
    num_chunks = int(file_size_mb / (max_size_mb * 0.55)) + 1
    chunk_duration = total_duration / num_chunks

    logger.info(f"מפצל {file_size_mb:.1f}MB ל-{num_chunks} חלקים ({chunk_duration:.0f} שניות כל אחד)")

    tmp_dir = tempfile.mkdtemp(prefix="zoom_split_")
    chunk_paths = []

    for i in range(num_chunks):
        start = i * chunk_duration
        chunk_path = os.path.join(tmp_dir, f"chunk_{i:03d}.m4a")

        cmd = [
            "ffmpeg", "-y", "-i", audio_path,
            "-ss", str(start), "-t", str(chunk_duration),
            "-c:a", "aac", "-b:a", "64k",  # קידוד מחדש ב-bitrate נמוך וקבוע
            "-loglevel", "error",
            chunk_path,
        ]
        result = subprocess.run(cmd, capture_output=True, text=True)

        if result.returncode == 0 and os.path.exists(chunk_path):
            chunk_size = os.path.getsize(chunk_path) / (1024 * 1024)
            logger.info(f"  חלק {i+1}/{num_chunks}: {chunk_size:.1f}MB")
            chunk_paths.append(chunk_path)
        else:
            logger.warning(f"  חלק {i+1} נכשל: {result.stderr}")

    return chunk_paths


def _transcribe_single(audio_path: str, client: OpenAI, config: dict, logger: logging.Logger) -> Optional[dict]:
    audio_path = os.path.expanduser(audio_path)
    """מתמלל קובץ אודיו בודד (עד 25MB) עם Whisper API."""

    def do_transcribe():
        with open(audio_path, "rb") as audio_file:
            response = client.audio.transcriptions.create(
                model=config.get("whisper_model", "whisper-1"),
                file=audio_file,
                response_format="verbose_json",
                timestamp_granularities=["word"],
            )
        return response

    try:
        result = api_call_with_retry(do_transcribe, logger=logger)

        transcript_text = result.text if hasattr(result, 'text') else ""
        words = []
        if hasattr(result, 'words') and result.words:
            words = [{"word": w.word, "start": w.start, "end": w.end} for w in result.words]

        detected_lang = result.language if hasattr(result, 'language') else None
        return {
            "transcript": transcript_text,
            "words": words,
            "whisper_language": detected_lang,
        }

    except Exception as e:
        logger.error(f"שגיאת תמלול: {e}")
        return None


def transcribe_audio(audio_path: str, client: OpenAI, config: dict, logger: logging.Logger) -> Optional[dict]:
    audio_path = os.path.expanduser(audio_path)
    """מתמלל קובץ אודיו עם Whisper API כולל word-level timestamps.

    אם הקובץ גדול מדי — מפצל אוטומטית עם ffmpeg ומתמלל כל חלק.
    מחזיר: dict עם transcript (טקסט), words (רשימת מילים עם timestamps), language
    """
    size_mb = os.path.getsize(audio_path) / (1024 * 1024)
    max_size = config.get("max_audio_size_mb", 25)

    # קובץ קטן — תמלול ישיר
    if size_mb <= max_size:
        logger.info(f"מתמלל: {os.path.basename(audio_path)} ({size_mb:.1f}MB)")
        return _transcribe_single(audio_path, client, config, logger)

    # קובץ גדול — פיצול ותמלול
    logger.info(f"קובץ גדול ({size_mb:.1f}MB > {max_size}MB) — מפצל אוטומטית...")
    chunk_paths = _split_audio(audio_path, max_size, logger)

    if not chunk_paths:
        logger.error("פיצול נכשל!")
        return None

    # תמלול כל חלק
    all_transcript = []
    all_words = []
    detected_lang = None
    time_offset = 0.0

    for i, chunk_path in enumerate(chunk_paths):
        logger.info(f"מתמלל חלק {i+1}/{len(chunk_paths)}...")
        chunk_result = _transcribe_single(chunk_path, client, config, logger)

        if chunk_result is None:
            logger.warning(f"  חלק {i+1} — תמלול נכשל, ממשיך...")
            continue

        all_transcript.append(chunk_result["transcript"])

        # עדכון timestamps — הוספת ההיסט של החלק הנוכחי
        for w in chunk_result["words"]:
            w["start"] += time_offset
            w["end"] += time_offset
            all_words.append(w)

        if not detected_lang and chunk_result.get("whisper_language"):
            detected_lang = chunk_result["whisper_language"]

        # חישוב היסט לחלק הבא (מתוך אורך הקובץ)
        try:
            probe = subprocess.run(
                ["ffprobe", "-v", "error", "-show_entries", "format=duration",
                 "-of", "default=noprint_wrappers=1:nokey=1", chunk_path],
                capture_output=True, text=True
            )
            time_offset += float(probe.stdout.strip())
        except Exception:
            # fallback: שימוש ב-timestamp של המילה האחרונה
            if chunk_result["words"]:
                time_offset = chunk_result["words"][-1]["end"]

    # ניקוי קבצים זמניים
    import shutil
    tmp_dir = os.path.dirname(chunk_paths[0]) if chunk_paths else None
    if tmp_dir and tmp_dir.startswith(tempfile.gettempdir()):
        shutil.rmtree(tmp_dir, ignore_errors=True)

    combined_text = " ".join(all_transcript)
    logger.info(f"תמלול הושלם: {len(combined_text)} תווים, {len(all_words)} מילים עם timestamps ({len(chunk_paths)} חלקים)")

    return {
        "transcript": combined_text,
        "words": all_words,
        "whisper_language": detected_lang,
    }


# ─── עזר: בחירת מודל לפי מסלול ────────────────────────────────────

def _get_model_for_route(route_id: str, config: dict, default_model: str) -> str:
    """מחזיר את המודל המתאים למסלול לפי config, או את ברירת המחדל."""
    model_map = config.get("model_per_route", {})
    return model_map.get(route_id, default_model)


# ─── שלב 2: ניתוב ────────────────────────────────────────────────

def route_transcript(transcript: str, file_name: str, prompts_dir: str,
                     client: OpenAI, model: str, logger: logging.Logger,
                     config: dict = None) -> Optional[dict]:
    """מריץ פרומפט ניתוב ומחזיר route_id עם metadata."""

    # בחירת מודל לניתוב
    if config:
        model = _get_model_for_route("_routing", config, model)
    logger.info(f"  מודל לניתוב: {model}")

    routing_prompt_path = os.path.join(prompts_dir, "routing.txt")
    if not os.path.exists(routing_prompt_path):
        logger.error(f"פרומפט ניתוב לא נמצא: {routing_prompt_path}")
        return None

    with open(routing_prompt_path, "r", encoding="utf-8") as f:
        routing_system_prompt = f.read()

    # בונה את הקלט לפרומפט הניתוב
    user_message = f'file_name: "{file_name}"\n\ntranscript:\n{transcript}'

    def do_route():
        response = client.chat.completions.create(
            model=model,
            messages=[
                {"role": "system", "content": routing_system_prompt},
                {"role": "user", "content": user_message},
            ],
            temperature=0.1,
            response_format={"type": "json_object"},
        )
        return response.choices[0].message.content

    try:
        raw_response = api_call_with_retry(do_route, logger=logger)
        routing_result = json.loads(raw_response)

        display_name = routing_result.get("display_name", file_name)
        routing_notes = routing_result.get("routing_notes", "")

        # תמיכה בפורמט החדש (routes כרשימה) וגם בפורמט הישן (route_id בודד)
        routes_raw = routing_result.get("routes", [])
        if not routes_raw and routing_result.get("route_id"):
            # פורמט ישן — המרה לרשימה
            routes_raw = [{
                "route_id": routing_result["route_id"],
                "confidence": routing_result.get("confidence", 0),
                "low_confidence": routing_result.get("low_confidence", False),
                "evidence_excerpts": routing_result.get("evidence_excerpts", []),
                "why": "",
            }]

        routes = []
        for r in routes_raw:
            rid = r.get("route_id", "other_general")
            if rid not in VALID_ROUTE_IDS:
                logger.warning(f"route_id לא מוכר: {rid}, מדלג")
                continue
            routes.append({
                "route_id": rid,
                "confidence": r.get("confidence", 0),
                "low_confidence": r.get("low_confidence", False),
                "evidence_excerpts": r.get("evidence_excerpts", []),
                "why": r.get("why", ""),
            })

        if not routes:
            routes = [{
                "route_id": "other_general",
                "confidence": 0.2,
                "low_confidence": True,
                "evidence_excerpts": [],
                "why": "לא נמצאו מסלולים מתאימים",
            }]

        route_names = [r["route_id"] for r in routes]
        logger.info(f"ניתוב: {', '.join(route_names)} (display: {display_name})")

        return {
            "routes": routes,
            "display_name": display_name,
            "routing_notes": routing_notes,
        }

    except Exception as e:
        logger.error(f"שגיאת ניתוב: {e}")
        return None


# ─── עזר: הוספת timestamps לתמלול ──────────────────────────────────

def format_transcript_with_timestamps(transcript: str, words: list) -> str:
    """משלב word-level timestamps לתוך הטקסט של התמלול.

    כל 30 שניות מוסיף סימון [HH:MM:SS] לפני המילה הקרובה ביותר.
    אם אין מילים עם timestamps — מחזיר את הטקסט המקורי.
    """
    if not words:
        return transcript

    # בניית תמלול חדש עם timestamps כל 30 שניות
    interval_seconds = 30
    next_marker = 0.0
    result_parts = []
    last_timestamp_inserted = -1

    for i, w in enumerate(words):
        start = w.get("start", 0)
        word_text = w.get("word", "")

        # אם הגענו לנקודת ה-timestamp הבאה
        if start >= next_marker:
            hours = int(start // 3600)
            minutes = int((start % 3600) // 60)
            seconds = int(start % 60)
            ts_label = f"[{hours:02d}:{minutes:02d}:{seconds:02d}]"
            result_parts.append(f"\n{ts_label} ")
            next_marker = start + interval_seconds

        result_parts.append(word_text + " ")

    timestamped_text = "".join(result_parts).strip()

    # הוספת סיכום timestamps בראש המסמך
    if words:
        total_seconds = words[-1].get("end", 0)
        hours = int(total_seconds // 3600)
        minutes = int((total_seconds % 3600) // 60)
        header = f"[תמלול עם timestamps — אורך כולל: {hours} שעות ו-{minutes} דקות]\n\n"
        return header + timestamped_text

    return timestamped_text


# ─── שלב 3: הרצת פרומפט ייעודי ──────────────────────────────────

def run_target_prompt(transcript: str, file_name: str, route_id: str,
                      prompts_dir: str, client: OpenAI, model: str,
                      logger: logging.Logger, words: list = None,
                      config: dict = None) -> dict:
    """מריץ את הפרומפט הייעודי לפי route_id.

    מחזיר: dict עם output_text (הפלט), is_error, error_reason
    words: רשימת מילים עם timestamps מ-Whisper (אופציונלי)
    config: הגדרות — משמש לבחירת מודל לפי מסלול
    """

    # בחירת מודל לפי מסלול
    if config:
        model = _get_model_for_route(route_id, config, model)
    logger.info(f"  מודל למסלול {route_id}: {model}")

    # other_general — סיכום קצר ללא פרומפט חיצוני
    if route_id == "other_general":
        return _generate_general_summary(transcript, file_name, client, model, logger)

    # טוען פרומפט ייעודי
    prompt_file = ROUTE_TO_PROMPT_FILE.get(route_id)
    if not prompt_file:
        return {"output_text": "", "is_error": True, "error_reason": f"אין פרומפט למסלול {route_id}"}

    prompt_path = os.path.join(prompts_dir, prompt_file)
    if not os.path.exists(prompt_path):
        return {"output_text": "", "is_error": True, "error_reason": f"קובץ פרומפט חסר: {prompt_file}"}

    with open(prompt_path, "r", encoding="utf-8") as f:
        system_prompt = f.read()

    # שילוב timestamps בתמלול אם יש
    if words:
        timestamped_transcript = format_transcript_with_timestamps(transcript, words)
        logger.info(f"תמלול עם timestamps: {len(timestamped_transcript)} תווים ({len(words)} מילים)")
    else:
        timestamped_transcript = transcript

    # מסלולים שדורשים עיבוד רב-שלבי
    MULTI_STEP_ROUTES = ("lesson_knowledge_rich",)

    if route_id in MULTI_STEP_ROUTES:
        return _run_multi_step_extraction(
            timestamped_transcript, file_name, route_id,
            system_prompt, client, model, logger
        )

    user_message = f'file_name: "{file_name}"\n\ntranscript:\n{timestamped_transcript}'

    # פרומפטים שמחזירים טקסט (או טקסט + JSON בסוף)
    # רק org_depth_extraction_for_content מחזיר JSON טהור
    TEXT_OUTPUT_ROUTES = (
        "implementation_work_session_email",
        "internal_regular_email",
        "org_characterization_post_sale",
        "org_sales_prep_psych_persona",
        "lesson_knowledge_rich",
        "lesson_student_success_quotes",
        "lesson_student_stories",
    )
    expects_json = route_id not in TEXT_OUTPUT_ROUTES

    def do_process():
        kwargs = {
            "model": model,
            "messages": [
                {"role": "system", "content": system_prompt},
                {"role": "user", "content": user_message},
            ],
            "temperature": 0.2,
        }
        if expects_json:
            kwargs["response_format"] = {"type": "json_object"}

        response = client.chat.completions.create(**kwargs)
        return response.choices[0].message.content

    try:
        raw_output = api_call_with_retry(do_process, logger=logger)

        # בדיקת שגיאה מהפרומפט עצמו (בדיקת סף)
        if expects_json:
            try:
                parsed = json.loads(raw_output)
                if parsed.get("error") == True or parsed.get("is_implementation") == False or \
                   parsed.get("is_internal_regular") == False or parsed.get("is_characterization") == False:
                    reason = parsed.get("reason", parsed.get("classification_reason", "הפרומפט זיהה אי-התאמה"))
                    logger.warning(f"פרומפט יעד החזיר שגיאה: {reason}")
                    return {
                        "output_text": raw_output,
                        "is_error": True,
                        "error_reason": reason,
                    }
            except json.JSONDecodeError:
                pass

        # ניקוי תגי HTML מהפלט
        raw_output = _clean_html_tags(raw_output)

        logger.info(f"פרומפט יעד הושלם: {len(raw_output)} תווים")
        return {"output_text": raw_output, "is_error": False, "error_reason": None}

    except Exception as e:
        logger.error(f"שגיאת פרומפט יעד: {e}")
        return {"output_text": "", "is_error": True, "error_reason": str(e)}


def _clean_html_tags(text: str) -> str:
    """מנקה תגי HTML (כמו <br>) מטקסט פלט."""
    # המרת <br>, <br/>, <br /> לשורה חדשה
    text = re.sub(r'<br\s*/?>', '\n', text, flags=re.IGNORECASE)
    # הסרת תגים אחרים
    text = re.sub(r'</?(?:p|div|span|b|i|u|em|strong)[^>]*>', '', text, flags=re.IGNORECASE)
    return text


# ─── עיבוד רב-שלבי למסמך ידע עשיר ──────────────────────────────

def _run_multi_step_extraction(transcript: str, file_name: str, route_id: str,
                                original_prompt: str, client: OpenAI, model: str,
                                logger: logging.Logger) -> dict:
    """מריץ עיבוד רב-שלבי להפקת מסמך ידע עשיר.

    שלב 1: זיהוי נושאים ומבנה כולל
    שלב 2: העמקה בכל נושא (פרומפטים, תהליכים, טעויות, תובנות)
    שלב 3: חילוץ רכיבים חוצי-נושאים (שאלות, מטפורות, רגעי וואו)
    שלב 4: הרכבה סופית — מסמך ידע + JSON אינדקס
    """
    logger.info("🔄 מתחיל עיבוד רב-שלבי למסמך ידע...")

    # ─── שלב 1: זיהוי נושאים ומבנה ───
    logger.info("  שלב 1/4: זיהוי נושאים ומבנה כללי...")

    step1_prompt = """אתה מנתח תמלולי שיעורים מתחום הבינה המלאכותית.
קיבלת תמלול מלא של שיעור. המשימה שלך בשלב זה היא רק לזהות את המבנה:

1. זהה את כל הנושאים המרכזיים שנדונו בשיעור (בדרך כלל 3-7 נושאים).
2. לכל נושא, רשום: שם הנושא, טווח זמן, תיאור קצר, האם יש תהליכים/הדגמות/פרומפטים.
3. זהה מטא-נתונים: כותרת השיעור, מספר השיעור, מחזור הקורס, שם המדריך/ה.
4. תאר בפסקה אחת את הזרימה הלימודית הכללית.

התעלם מדברי חולין, בדיחות, הפסקות, או חזרות לא מהותיות.
חשוב: אם יש timestamps בתמלול, ציין אותם במדויק. אם אין — כתוב "לא זמין".

החזר JSON בדיוק במבנה הבא (אל תשנה את שמות המפתחות):
