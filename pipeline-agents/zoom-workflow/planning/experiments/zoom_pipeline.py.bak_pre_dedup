                sections.append(f"**משמעות:** {q.get('meaning_2_3_words', '')}")
                if q.get("teacher_link_evidence"):
                    sections.append(f"**קשר למרצה:** {q['teacher_link_evidence']}")

    elif route_id == "lesson_student_stories":
        sections.append("# אינדקס סיפורי תלמידים")

        source = data.get("source", {})
        if source:
            if source.get("course_cycle_as_said"):
                sections.append(f"**מחזור:** {source['course_cycle_as_said']}")
            if source.get("lesson_number_as_said"):
                sections.append(f"**שיעור:** {source['lesson_number_as_said']}")

        if data.get("error"):
            sections.append(f"\n**שגיאה:** {data.get('error_reason', 'לא ידוע')}")
        else:
            stories = data.get("stories", [])
            if stories:
                sections.append(f"\nנמצאו {data.get('stories_count', len(stories))} סיפורים/רגעים:")
                for i, s in enumerate(stories, 1):
                    sections.append(f"\n### {i}. {s.get('type', 'רגע')}")
                    sections.append(f"**תיאור:** {s.get('short_description_one_sentence', '')}")

                    if s.get("quote_key"):
                        sections.append(f'> "{s["quote_key"]}"')

                    who = s.get("who_said_it", "")
                    name = s.get("speaker_name")
                    if name:
                        sections.append(f"**דובר/ת:** {name} ({who})")
                    elif who:
                        sections.append(f"**דובר/ת:** {who}")

                    ts_start = s.get("timestamp_start", "")
                    ts_end = s.get("timestamp_end")
                    if ts_start:
                        ts_text = f"{ts_start} — {ts_end}" if ts_end else ts_start
                        sections.append(f"**זמן:** {ts_text}")

                    tags = s.get("topics_tags", [])
                    if tags:
                        sections.append(f"**תגים:** {', '.join(tags)}")

                    if s.get("source_excerpt"):
                        sections.append(f"\n*קטע מקור:* {s['source_excerpt']}")

                    if s.get("notes"):
                        sections.append(f"*הערה:* {s['notes']}")
            else:
                sections.append("\nלא נמצאו סיפורים משמעותיים בתמלול זה.")

    else:
        # fallback — מציג JSON כטקסט מובנה
        sections.append(f"# פלט — {route_id}")
        _add_json_fields_recursively(data, sections)

    return "\n".join(sections)


def _add_json_fields_recursively(data, sections, indent=0, skip_keys=None):
    """עזר — ממיר JSON שרירותי לרשימת שורות קריאות."""
    skip = skip_keys or []
    if isinstance(data, dict):
        for key, value in data.items():
            if key in skip or key == "file_name":
                continue
            if isinstance(value, (dict, list)):
                sections.append(f"\n{'#' * min(indent + 2, 4)} {key}")
                _add_json_fields_recursively(value, sections, indent + 1)
            elif value is not None:
                sections.append(f"**{key}:** {value}")
    elif isinstance(data, list):
        for item in data:
            if isinstance(item, dict):
                _add_json_fields_recursively(item, sections, indent)
                sections.append("")  # שורה ריקה בין פריטים
            elif item is not None:
                sections.append(f"- {item}")


# ─── שלב 5: שמירה ב-Notion ───────────────────────────────────────

def save_to_notion(recording: dict, routing_result: dict, outputs: dict,
                   transcript_text: str, language: str,
                   config: dict, logger: logging.Logger) -> bool:
    """שומר שורה אחת בדאטהבייס Notion עם כל הפלטים בעמודות נפרדות.

    outputs: dict מ-route_id ל-output dict (כל אחד עם output_text, is_error, error_reason)
    routing_result: dict עם routes, display_name, routing_notes
    """

    notion_key = os.environ.get(config.get("notion_api_key_env_var", "NOTION_API_KEY"))
    if not notion_key:
        logger.error("מפתח Notion API חסר! הגדר משתנה סביבה NOTION_API_KEY")
        return False

    database_id = config["notion_database_id"]
    routes = routing_result["routes"]
    display_name = routing_result.get("display_name", recording["folder_name"])

    # קביעת סטטוס — שגיאה אם כל הפלטים נכשלו
    any_error = any(outputs[r["route_id"]]["is_error"] for r in routes if r["route_id"] in outputs)
    any_low_conf = any(r["low_confidence"] for r in routes)
    all_error = all(outputs[r["route_id"]]["is_error"] for r in routes if r["route_id"] in outputs)

    if all_error:
        status = "שגיאה"
    elif any_low_conf:
        status = "לבדיקה ידנית"
    else:
        status = "הצלחה"

    # רשימת מסלולים שרצו
    route_ids = [r["route_id"] for r in routes]

    # קטגוריה ראשית — לפי המסלול עם הביטחון הגבוה ביותר
    primary_route = max(routes, key=lambda r: r["confidence"])
    primary_category = ROUTE_TO_CATEGORY.get(primary_route["route_id"], "כללי")

    # הכנת routing_notes
    routing_notes_text = routing_result.get("routing_notes", "")
    if isinstance(routing_notes_text, dict):
        routing_notes_text = str(routing_notes_text)

    # בניית properties
    properties = {
        "שם הקלטה": {"title": [{"text": {"content": display_name[:100]}}]},
        "מסלולים": {"multi_select": [{"name": rid} for rid in route_ids]},
        "קטגוריה": {"select": {"name": primary_category}},
        "סטטוס": {"select": {"name": status}},
        "נתיב קובץ": {"rich_text": [{"text": {"content": recording["audio_path"][:2000]}}]},
    }

    # תאריך הקלטה
    if recording.get("date"):
        properties["תאריך הקלטה"] = {"date": {"start": recording["date"]}}

    # הערות ניתוב — עמודה נמחקה מ-Notion, הנתון נשמר בלוג בלבד
    if routing_notes_text:
        logger.info(f"הערות ניתוב: {routing_notes_text[:500]}")

    # איסוף שגיאות
    error_reasons = []
    for route_info in routes:
        rid = route_info["route_id"]
        if rid in outputs and outputs[rid].get("error_reason"):
            error_reasons.append(f"{rid}: {outputs[rid]['error_reason']}")

    if error_reasons:
        properties["סיבת שגיאה"] = {"rich_text": [{"text": {"content": "; ".join(error_reasons)[:2000]}}]}

    # בניית תוכן הדף — כל פלט מפורמט בגוף הדף
    content_blocks = []
    for route_info in routes:
        rid = route_info["route_id"]
        if rid not in outputs or outputs[rid]["is_error"]:
            continue
        output_text = outputs[rid]["output_text"]

        # המרת הפלט למרקדאון מפורמט ואז לבלוקי Notion
        formatted_markdown = format_output_for_notion(output_text, rid)
        formatted_blocks = _text_to_notion_blocks(formatted_markdown)
        content_blocks.extend(formatted_blocks)

        # קו הפרדה בין מסלולים
        content_blocks.append({
            "object": "block",
            "type": "divider",
            "divider": {},
        })

    # תמלול מלא ב-toggle עם פסקאות רגילות
    transcript_blocks = []
    if transcript_text:
        transcript_blocks.append({
            "object": "block",
            "type": "divider",
            "divider": {},
        })
        transcript_chunks = [transcript_text[i:i+2000] for i in range(0, len(transcript_text), 2000)]
        toggle_children = []
        for chunk in transcript_chunks:
            toggle_children.append({
                "object": "block",
                "type": "paragraph",
                "paragraph": {
                    "rich_text": [{"type": "text", "text": {"content": chunk}}],
                },
            })
        transcript_blocks.append({
            "object": "block",
            "type": "toggle",
            "toggle": {
                "rich_text": [{"type": "text", "text": {"content": "תמלול מלא"}}],
                "children": toggle_children[:100],
            },
        })

    # חיבור כל הבלוקים — תוכן + תמלול
    all_blocks = content_blocks + transcript_blocks

    # Notion מגביל ל-100 בלוקים בקריאה אחת.
    # אם יש יותר: יוצרים את הדף עם 100 הראשונים, ואז מוסיפים את השאר במנות.
    first_batch = all_blocks[:100]
    remaining_batches = [all_blocks[i:i+100] for i in range(100, len(all_blocks), 100)]

    # שליחה ל-Notion API
    headers = {
        "Authorization": f"Bearer {notion_key}",
        "Content-Type": "application/json",
        "Notion-Version": "2022-06-28",
    }

    payload = {
        "parent": {"database_id": database_id},
        "properties": properties,
        "children": first_batch,
    }

    def do_create():
        resp = requests.post("https://api.notion.com/v1/pages", headers=headers, json=payload, timeout=30)
        if resp.status_code != 200:
            logger.error(f"Notion response ({resp.status_code}): {resp.text[:1000]}")
        resp.raise_for_status()
        return resp.json()

    try:
        result = api_call_with_retry(do_create, logger=logger)
        page_id = result.get("id", "")
        page_url = result.get("url", "")
        logger.info(f"נשמר ב-Notion: {page_url}")

        # הוספת בלוקים נוספים אם יש
        for batch_num, batch in enumerate(remaining_batches, 1):
            logger.info(f"מוסיף בלוקים נוספים (מנה {batch_num}, {len(batch)} בלוקים)...")
            append_url = f"https://api.notion.com/v1/blocks/{page_id}/children"

            def do_append(b=batch):
                resp = requests.patch(append_url, headers=headers,
                                      json={"children": b}, timeout=30)
                if resp.status_code != 200:
                    logger.error(f"Notion append ({resp.status_code}): {resp.text[:500]}")
                resp.raise_for_status()
                return resp.json()

            api_call_with_retry(do_append, logger=logger)

        return True

    except Exception as e:
        logger.error(f"שגיאת Notion: {e}")
        return False


def _text_to_notion_blocks(markdown_text: str) -> list:
    """ממיר מרקדאון פשוט לבלוקים של Notion API.

    תומך ב: כותרות (#), מספרים (1. / 1) / 1.1), תבליטים (-/•),
    ציטוטים (>), הזחות, טקסט רגיל.
    """
    blocks = []
    lines = markdown_text.split("\n")

    for line in lines:
        stripped = line.strip()
        if not stripped:
            continue

        # כותרת 1
        if stripped.startswith("# ") and not stripped.startswith("## "):
            blocks.append({
                "object": "block",
                "type": "heading_1",
                "heading_1": {"rich_text": [{"type": "text", "text": {"content": stripped[2:].strip()[:2000]}}]},
            })
        # כותרת 2
        elif stripped.startswith("## "):
            blocks.append({
                "object": "block",
                "type": "heading_2",
                "heading_2": {"rich_text": [{"type": "text", "text": {"content": stripped[3:].strip()[:2000]}}]},
            })
        # כותרת 3
        elif stripped.startswith("### "):
            blocks.append({
                "object": "block",
                "type": "heading_3",
                "heading_3": {"rich_text": [{"type": "text", "text": {"content": stripped[4:].strip()[:2000]}}]},
            })
        # ציטוט
        elif stripped.startswith("> "):
            blocks.append({
                "object": "block",
                "type": "quote",
                "quote": {"rich_text": [{"type": "text", "text": {"content": stripped[2:].strip()[:2000]}}]},
            })
        # תבליט (כולל מוזח)
        elif stripped.startswith("- ") or stripped.startswith("• "):
            prefix_len = 2
            blocks.append({
                "object": "block",
                "type": "bulleted_list_item",
                "bulleted_list_item": {"rich_text": _parse_inline_formatting(stripped[prefix_len:].strip()[:2000])},
            })
        # כותרת ממוספרת ראשית — 1) או 2) וכד'
        elif re.match(r'^\d+\)\s', stripped):
            text = re.sub(r'^\d+\)\s*', '', stripped)
            blocks.append({
                "object": "block",
                "type": "heading_2",
                "heading_2": {"rich_text": _parse_inline_formatting(text[:2000])},
            })
        # כותרת ממוספרת משנית — 1.1 או 2.3 וכד'
        elif re.match(r'^\d+\.\d+\s', stripped):
            text = re.sub(r'^\d+\.\d+\s*', '', stripped)
            blocks.append({
                "object": "block",
                "type": "heading_3",
                "heading_3": {"rich_text": _parse_inline_formatting(text[:2000])},
            })
        # פריט ממוספר — 1. טקסט
        elif re.match(r'^\d+\.\s', stripped):
            text = re.sub(r'^\d+\.\s*', '', stripped)
            blocks.append({
                "object": "block",
                "type": "numbered_list_item",
                "numbered_list_item": {"rich_text": _parse_inline_formatting(text[:2000])},
            })
        # טקסט רגיל (כולל הדגשות)
        else:
            blocks.append({
                "object": "block",
                "type": "paragraph",
                "paragraph": {"rich_text": _parse_inline_formatting(stripped[:2000])},
            })

    return blocks


def _parse_inline_formatting(text: str) -> list:
    """מפענח הדגשות **bold** בטקסט ומחזיר rich_text של Notion."""
    parts = []
    pattern = r'\*\*(.+?)\*\*'
    last_end = 0

    for match in re.finditer(pattern, text):
        # טקסט רגיל לפני ההדגשה
        if match.start() > last_end:
            plain = text[last_end:match.start()]
            if plain:
                parts.append({"type": "text", "text": {"content": plain}})
        # טקסט מודגש
        parts.append({
            "type": "text",
            "text": {"content": match.group(1)},
            "annotations": {"bold": True},
        })
        last_end = match.end()

    # טקסט שנשאר אחרי ההדגשה האחרונה
    if last_end < len(text):
        remaining = text[last_end:]
        if remaining:
            parts.append({"type": "text", "text": {"content": remaining}})

    # אם אין הדגשות, מחזיר את הטקסט כמו שהוא
    if not parts:
        parts.append({"type": "text", "text": {"content": text}})

    return parts


# ─── הרצה ראשית ───────────────────────────────────────────────────

def main():
    """הרצה ראשית של הפייפליין."""

    # טעינת הגדרות
    config_path = sys.argv[1] if len(sys.argv) > 1 else "config.json"

    if not os.path.exists(config_path):
        print(f"קובץ הגדרות לא נמצא: {config_path}")
        sys.exit(1)

    config = load_config(config_path)

    # הגדרת נתיבים יחסיים ל-config
    script_dir = os.path.dirname(os.path.abspath(__file__))
    prompts_dir = os.path.join(script_dir, config.get("prompts_dir", "prompts"))
    processed_path = os.path.join(script_dir, config.get("processed_files_path", "processed_files.json"))
    log_file = os.path.join(script_dir, config.get("log_file", "pipeline.log"))

    # אתחול
    logger = setup_logging(log_file)
    logger.info("=" * 60)
    logger.info("מתחיל הרצה של zoom_pipeline")
    logger.info("=" * 60)

    # בדיקת מפתחות API
    openai_key = os.environ.get(config.get("openai_api_key_env_var", "OPENAI_API_KEY"))
    if not openai_key:
        logger.error("מפתח OpenAI API חסר! הגדירי משתנה סביבה OPENAI_API_KEY")
        sys.exit(1)

    notion_key = os.environ.get(config.get("notion_api_key_env_var", "NOTION_API_KEY"))
    if not notion_key:
        logger.error("מפתח Notion API חסר! הגדירי משתנה סביבה NOTION_API_KEY")
        sys.exit(1)

    # אתחול OpenAI client
    client = OpenAI(api_key=openai_key)
    model = config.get("openai_model_for_prompts", "gpt-4o")

    # טעינת רשימת קבצים מעובדים
    processed = load_processed_files(processed_path)

    # שלב 0: סריקה
    zoom_path = os.path.expanduser(config["zoom_recordings_path"])
    recordings = scan_zoom_folder(zoom_path, processed, logger)

    if not recordings:
        logger.info("אין הקלטות חדשות. מסיים.")
        return

    # עיבוד כל הקלטה
    success_count = 0
    error_count = 0

    for i, recording in enumerate(recordings, 1):
        logger.info(f"\n--- הקלטה {i}/{len(recordings)}: {recording['folder_name']} ---")

        try:
            # שלב 1: תמלול
            transcription = transcribe_audio(recording["audio_path"], client, config, logger)
            if not transcription:
                logger.warning(f"דילוג — תמלול נכשל: {recording['folder_name']}")
                processed[recording["audio_path"]] = {
                    "status": "transcription_failed",
                    "timestamp": datetime.now().isoformat(),
                }
                save_processed_files(processed_path, processed)
                error_count += 1
                continue

            transcript_text = transcription["transcript"]
            language = detect_language(transcript_text)

            # שלב 2: ניתוב (מחזיר רשימת מסלולים)
            routing_result = route_transcript(
                transcript_text, recording["folder_name"],
                prompts_dir, client, model, logger,
                config=config
            )
            if not routing_result:
                logger.warning(f"דילוג — ניתוב נכשל: {recording['folder_name']}")
                processed[recording["audio_path"]] = {
                    "status": "routing_failed",
                    "timestamp": datetime.now().isoformat(),
                }
                save_processed_files(processed_path, processed)
                error_count += 1
                continue

            display_name = routing_result["display_name"]
            routes = routing_result["routes"]
            recording["display_name"] = display_name

            # שלב 3: הרצת כל פרומפט — איסוף פלטים ל-dict
            words = transcription.get("words", [])
            outputs = {}
            for route_info in routes:
                route_id = route_info["route_id"]
                logger.info(f"  מעבד מסלול: {route_id}")

                output = run_target_prompt(
                    transcript_text, recording["folder_name"],
                    route_id, prompts_dir, client, model, logger,
                    words=words, config=config
                )
                outputs[route_id] = output

            # שלב 4+5: שמירה אחת ב-Notion עם כל הפלטים
            saved = save_to_notion(
                recording, routing_result, outputs,
                transcript_text, language, config, logger
            )

            route_ids_done = [r["route_id"] for r in routes]

            # עדכון קבצים מעובדים
            processed[recording["audio_path"]] = {
                "status": "success" if saved else "error",
                "route_ids": route_ids_done,
                "timestamp": datetime.now().isoformat(),
            }
            save_processed_files(processed_path, processed)

            if saved:
                success_count += 1
            else:
                error_count += 1

        except Exception as e:
            logger.error(f"שגיאה כללית בעיבוד {recording['folder_name']}: {e}")
            processed[recording["audio_path"]] = {
                "status": "general_error",
                "error": str(e),
                "timestamp": datetime.now().isoformat(),
            }
            save_processed_files(processed_path, processed)
            error_count += 1

    # סיכום
    logger.info(f"\n{'=' * 60}")
    logger.info(f"סיום הרצה: {success_count} הצלחות, {error_count} שגיאות מתוך {len(recordings)} הקלטות")
    logger.info(f"{'=' * 60}")


if __name__ == "__main__":
    main()
