#!/bin/bash
# ============================================================
#  הפעלה ידנית — שיחות מכירה אוטומציה
#  דאבל-קליק להרצה ידנית של הפייפליין פעם אחת.
# ============================================================

set -e

GREEN='\033[0;32m'
BLUE='\033[0;34m'
NC='\033[0m'

SCRIPT_DIR="$( cd "$( dirname "${BASH_SOURCE[0]}" )" && pwd )"
cd "$SCRIPT_DIR"

clear
echo ""
echo "════════════════════════════════════════════════════════════"
echo "   ▶️  הרצה ידנית — שיחות מכירה אוטומציה"
echo "════════════════════════════════════════════════════════════"
echo ""

if [ ! -d "venv" ]; then
    echo "✗ הסביבה לא הותקנה עדיין."
    echo "   דאבל-קליק על 'התקנה.command' קודם."
    echo ""
    read -p "לחצי Enter לסגור..."
    exit 1
fi

source venv/bin/activate
echo -e "${BLUE}▶ מריצה את הפייפליין...${NC}"
echo ""

python3 sales_pipeline.py

echo ""
echo -e "${GREEN}✓ הריצה הסתיימה${NC}"
echo ""
echo "לוג מלא: $SCRIPT_DIR/logs/"
echo ""
read -p "לחצי Enter לסגור..."
