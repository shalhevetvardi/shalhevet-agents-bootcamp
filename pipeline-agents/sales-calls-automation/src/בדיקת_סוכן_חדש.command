#!/bin/bash
# ============================================================
#  בדיקה ידנית של הסוכן החדש (email_draft_v2) על ליד אמיתי
# ============================================================

set -e

GREEN='\033[0;32m'
BLUE='\033[0;34m'
RED='\033[0;31m'
NC='\033[0m'

SCRIPT_DIR="$( cd "$( dirname "${BASH_SOURCE[0]}" )" && pwd )"
cd "$SCRIPT_DIR"

clear
echo ""
echo "════════════════════════════════════════════════════════════"
echo "   🧪  בדיקת סוכן המיילים החדש (גרסה 2)"
echo "════════════════════════════════════════════════════════════"
echo ""

if [ ! -d "venv" ]; then
    echo -e "${RED}✗ הסביבה לא הותקנה. הריצי התקנה.command קודם.${NC}"
    read -p "לחצי Enter לסגור..."
    exit 1
fi

source venv/bin/activate
python3 test_email_v2.py

echo ""
read -p "לחצי Enter לסגור..."
