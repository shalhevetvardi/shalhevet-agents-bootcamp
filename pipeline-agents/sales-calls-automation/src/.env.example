# ============================================================
#  שיחות מכירה אוטומציה — תבנית .env
#  ⚠️ זהו קובץ דוגמה בלבד — בלי ערכים אמיתיים!
#  להעתיק ל-.env ולמלא את הערכים האמיתיים.
# ============================================================

# --- Anthropic (Claude) ---
ANTHROPIC_API_KEY=sk-ant-...

# --- Airtable ---
AIRTABLE_API_KEY=pat...
AIRTABLE_BASE_ID=app...
AIRTABLE_TABLE_ID=tbl...

# --- Twilio ---
TWILIO_ACCOUNT_SID=AC...
TWILIO_AUTH_TOKEN=...
TWILIO_PHONE_NUMBER=+972...

# --- Calendly ---
CALENDLY_API_TOKEN=eyJ...
CALENDLY_USER_URI=https://api.calendly.com/users/...

# --- RunPod (ivrit.ai) ---
RUNPOD_API_KEY=rpa_...
RUNPOD_ENDPOINT_ID=...

# --- Gmail (OAuth via Refresh Token) ---
# 1. ליצור OAuth Client ב-Google Cloud Console (Desktop app)
# 2. להריץ auth_gmail.py פעם אחת — זה יצור refresh_token ויעדכן את .env
GOOGLE_CLIENT_ID=...apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=GOCSPX-...
GOOGLE_REFRESH_TOKEN=1//...

# --- Pipeline Config ---
LOOKBACK_HOURS=24
TIMEZONE=Asia/Jerusalem
