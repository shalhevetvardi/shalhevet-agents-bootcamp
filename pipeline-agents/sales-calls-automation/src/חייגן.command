#!/bin/bash
# ============================================================
#  חייגן אִימפּרוּב — דאבל-קליק להפעיל
#  פותח דפדפן עם רשימת הלידים מקלנדלי + כפתור חיוג לכל אחד
# ============================================================

set -e

GREEN='\033[0;32m'
BLUE='\033[0;34m'
RED='\033[0;31m'
NC='\033[0m'

SCRIPT_DIR="$( cd "$( dirname "${BASH_SOURCE[0]}" )" && pwd )"
cd "$SCRIPT_DIR"

clear
echo ""
echo "════════════════════════════════════════════════════════════"
echo "   📞  חייגן אִימפּרוּב"
echo "════════════════════════════════════════════════════════════"
echo ""

if [ ! -d "venv" ]; then
    echo -e "${RED}✗ הסביבה לא הותקנה.${NC}"
    echo "   הריצי קודם את 'התקנה.command'"
    echo ""
    read -p "לחצי Enter לסגור..."
    exit 1
fi

source venv/bin/activate
python3 dialer.py
