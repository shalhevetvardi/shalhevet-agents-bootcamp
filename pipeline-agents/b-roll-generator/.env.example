# Anthropic — for storyboard generation and prompt expansion
ANTHROPIC_API_KEY=sk-ant-your-key-here

# fal.ai — for Flux image generation and Kling video generation
FAL_KEY=your-fal-key-here

# Optional: override the Claude model
# CLAUDE_MODEL=claude-sonnet-4-6

# Optional: Flux configuration
# FLUX_ENDPOINT=fal-ai/flux-pro/v1.1
# FLUX_IMAGE_SIZE=portrait_16_9
# FLUX_PARALLEL=5

# Optional: Kling video configuration
# KLING_DURATION=5
# KLING_ASPECT_RATIO=9:16
# KLING_PARALLEL=5

# Optional: Custom LoRA for personal panels
# SHALHEVET_LORA_URL=
# SHALHEVET_LORA_TRIGGER=
